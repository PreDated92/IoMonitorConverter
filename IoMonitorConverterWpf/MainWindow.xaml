<Window x:Class="IoMonitorConverterWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IoMonitorConverterWpf"
        mc:Ignorable="d"
        Title="IO Monitor Converter" Height="650" Width="870">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- File Selection Panel -->
        <StackPanel Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,10">
            <!-- XML File List -->
            <Label Content="Available XML Files:" FontWeight="Bold"/>
            <TextBlock Text="{Binding CurrentXmlFolder}" 
                       Foreground="Gray" 
                       FontSize="10" 
                       Margin="0,0,0,5"
                       TextTrimming="CharacterEllipsis"/>
            <ListView ItemsSource="{Binding XmlFiles}"
                      SelectedItem="{Binding SelectedXmlFile, Mode=TwoWay}"
                      Height="120"
                      Margin="0,0,0,10">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="File Name" Width="400" DisplayMemberBinding="{Binding FileName}"/>
                        <GridViewColumn Header="Size" Width="80" DisplayMemberBinding="{Binding FileSizeFormatted}"/>
                        <GridViewColumn Header="Modified" Width="120" DisplayMemberBinding="{Binding ModifiedDate}"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <Label Content="XML Input File:" FontWeight="Bold"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" 
                         Text="{Binding XmlFilePath, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,5,0"/>
                <Button Grid.Column="1" 
                        Content="Browse..."
                        Command="{Binding BrowseXmlCommand}"/>
            </Grid>

            <Label Content="CSV Output File:" FontWeight="Bold" Margin="0,10,0,0"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" 
                         Text="{Binding CsvFilePath, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,5,0"/>
                <Button Grid.Column="1" 
                        Content="Browse..."
                        Command="{Binding BrowseCsvCommand}"/>
            </Grid>
        </StackPanel>

        <!-- Button Panel -->
        <StackPanel Grid.Column="0" Grid.Row="1" 
                    VerticalAlignment="Top"
                    Margin="0,0,10,0">
            <Button Content="Convert to CSV" 
                    Command="{Binding TextConvertCommand}"
                    Height="30"
                    Margin="0,0,0,10"/>
            <Button Content="Cancel" 
                    Command="{Binding CancelCommand}"
                    IsEnabled="{Binding IsCancellable}"
                    Height="30"
                    Margin="0,0,0,10"/>
            <ProgressBar Height="20"
                         IsIndeterminate="True"
                         Visibility="{Binding IsConverting, Converter={StaticResource BoolToVisibilityConverter}}"
                         Margin="0,0,0,10"/>
            <ProgressBar Height="20"
                         IsIndeterminate="True"
                         Visibility="{Binding IsLoadingPreview, Converter={StaticResource BoolToVisibilityConverter}}"
                         Margin="0,0,0,10"/>
            <TextBlock Text="{Binding StatusText}"
                       TextWrapping="Wrap"
                       Margin="0,10,0,0"/>
        </StackPanel>

        <!-- CSV Preview -->
        <DockPanel Grid.Column="1" Grid.Row="1">
            <Label Content="CSV Preview (first 10 records):" FontWeight="Bold" DockPanel.Dock="Top"/>
            <TextBox Text="{Binding PreviewText, Mode=OneWay}"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas"/>
        </DockPanel>
    </Grid>
</Window>

